{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Project-level Claude Code config — committed for collaborator parity. Per-user permissions: .claude/settings.local.json (gitignored). Hooks here are MANDATORY per Workflow v2.1 INV-WF-001 verifiable trigger rule.",
  "enableAllProjectMcpServers": true,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/session-start-banner.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Glob|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/architect-guard.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/block-env-edit.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/block-unsafe-merge.sh"
          }
        ]
      }
    ]
  }
}
